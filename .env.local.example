# ---- Anthropic (required for AI checks) ----
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides:
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_EFFORT=max        # max | xhigh | high | medium | low

# ---- Supabase (required to save/submit) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key (server-only, keep secret)

# ---- Reviewer dashboard password (required for /admin) ----
ADMIN_PASSWORD=choose-a-strong-password
